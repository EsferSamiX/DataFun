# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-string
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── LLM ─────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
LITELLM_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct
LITELLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# ── Database ─────────────────────────────────────────────────────────────────
# Requires pgvector extension: CREATE EXTENSION vector;
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/datafun

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Services ─────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001/mcp

# ── App ──────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=200
PROFILE_CACHE_TTL_SECONDS=86400
SUGGESTION_CACHE_TTL_SECONDS=86400
MAX_CHAT_HISTORY=10
